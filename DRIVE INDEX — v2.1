// Force-restart enrichment from a specific row
function restartEnrichmentFromRow(rowNumber) {
  PropertiesService.getScriptProperties().setProperty(CFG.props.pathRow, String(rowNumber || 2));
  startEnrichmentTriggers_();
  console.log(`Enrichment restarted from row ${rowNumber}`);
}

// Re-run deduplication pass on demand
function rerunDuplicateDetection() {
  runDuplicateDetection();
  console.log("Duplicate detection complete.");
}

// Clear delta cursor (forces delta to re-process recent activity)
function resetDeltaCursor() {
  storeFreshDeltaCursor_();
  console.log("Delta cursor reset to current position.");
}

// Inspect a single file ID — useful for debugging
function debugSingleFile(fileId) {
  if (!fileId) throw new Error("Pass a fileId string");
  const meta      = fetchFileMeta_(fileId);
  const access    = getGeneralAccess_(fileId);
  const parentIds = normalizeParentIds_(meta.parents);
  const path      = parentIds.length ? buildFolderPath_(parentIds[0]) : "(no parent)";
  const dept      = classifyDepartment_(path, meta.name);
  const project   = extractProjectName_(path);

  const report =
    `File ID   : ${fileId}\n` +
    `Name      : ${meta.name}\n` +
    `Type      : ${mimeToFileType_(meta.mimeType)}\n` +
    `Modified  : ${meta.modifiedTime}\n` +
    `Access    : ${access}\n` +
    `Parents   : ${parentIds.join(", ")}\n` +
    `Path      : ${path}\n` +
    `Dept      : ${dept}\n` +
    `Project   : ${project}`;

  console.log(report);
  note_(getIndexSheet_(), report);
  return report;
}
